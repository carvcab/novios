<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/widget_bg_notes">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tv_notes_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sin notas aún"
            android:textSize="15sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:singleLine="true"
            android:ellipsize="end"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/tv_notes_preview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Toca para crear tu primera nota"
        android:textSize="13sp"
        android:textColor="#AAFFFFFF"
        android:fontFamily="sans-serif"
        android:lineSpacingExtra="3dp"
        android:layout_marginTop="8dp"
        android:maxLines="4"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/tv_notes_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:textColor="#55FFD700"
        android:fontFamily="sans-serif"
        android:layout_marginTop="6dp" />

</LinearLayout>
