rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isMember() {
      return request.auth != null && (
        request.auth.uid == 'joeBcVn2o1hfXfU68rWNOyAZIqt2' ||
        request.auth.uid == 'Dd1X94n3gxg7leWtMtnLlxDVHcm2'
      );
    }

    function isInPareja() {
      return isMember() && (
        resource.data.miembros != null &&
        request.auth.uid in resource.data.miembros
      );
    }

    match /usuarios/{uid} {
      allow read: if isMember();
      allow write: if request.auth.uid == uid;
    }

    match /parejas/{parejaId} {
      allow read: if isMember();
      allow write: if isMember();
      match /{document=**} {
        allow read: if isMember();
        allow create: if isMember();
        allow update: if isMember();
        allow delete: if isMember();
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
